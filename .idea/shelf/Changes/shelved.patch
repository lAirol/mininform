<+><!DOCTYPE html>\r\n<html lang=\"ru\"><head>\r\n<meta http-equiv=\"content-type\" content=\"text/html; charset=UTF-8\">\r\n  <meta charset=\"UTF-8\">\r\n  <title>Заявление о регистрации СМИ</title>\r\n\r\n  <style>\r\n\r\n    body{\r\n      font-family: Arial, sans-serif;\r\n      background:#f4f6f8;\r\n      margin:0;\r\n      padding:40px;\r\n    }\r\n\r\n    .container{\r\n      max-width:900px;\r\n      margin:auto;\r\n    }\r\n\r\n    h1{\r\n      font-size:24px;\r\n    }\r\n\r\n    .step{\r\n      margin-top:40px;\r\n    }\r\n\r\n    .step{\r\n      display:none;\r\n    }\r\n\r\n    .step.active{\r\n      display:block;\r\n    }\r\n\r\n    .card{\r\n      background:white;\r\n      padding:20px;\r\n      border-radius:10px;\r\n      margin-bottom:20px;\r\n      box-shadow:0 2px 6px rgba(0,0,0,0.08);\r\n    }\r\n\r\n    .card h3{\r\n      margin-top:0;\r\n    }\r\n\r\n    .row{\r\n      display:flex;\r\n      gap:10px;\r\n      margin-bottom:10px;\r\n      flex-wrap: wrap;\r\n    }\r\n\r\n    .row > .flex-line {\r\n        flex: 1;\r\n        min-width: 200px;\r\n    }\r\n\r\n    /* Общие стили полей ввода — везде одинаково */\r\n    input:not([type=\"radio\"]):not([type=\"checkbox\"]),\r\n    select,\r\n    textarea{\r\n      width:100%;\r\n      padding:8px;\r\n      box-sizing:border-box;\r\n      font-family:inherit;\r\n      font-size:14px;\r\n    }\r\n\r\n    label{\r\n      font-size:14px;\r\n      display:block;\r\n      margin-bottom:5px;\r\n    }\r\n\r\n    button{\r\n      padding:10px 16px;\r\n      border:none;\r\n      border-radius:6px;\r\n      background:#2e7d32;\r\n      color:white;\r\n      cursor:pointer;\r\n    }\r\n\r\n    #stepNav #prevStep,\r\n    #stepNav #nextStep{\r\n      height:36px;\r\n      padding:0 18px;\r\n      border-radius:999px;\r\n      font-weight:600;\r\n      letter-spacing:0.2px;\r\n      text-transform:uppercase;\r\n    }\r\n    #stepNav #prevStep{\r\n      background:#fff;\r\n      color:#2e7d32;\r\n      border:1px solid #cfe6d2;\r\n    }\r\n    #stepNav #nextStep{\r\n      background:#1f6a2a;\r\n      color:#fff;\r\n      border:1px solid #1f6a2a;\r\n    }\r\n    #stepNav #prevStep:hover{ background:#f3faf4; }\r\n    #stepNav #nextStep:hover{ background:#1a5a23; border-color:#1a5a23; }\r\n\r\n    .form-footer-actions .btn-save-founder,\r\n    .form-footer-actions .btn-cancel-founder{\r\n      height:30px;\r\n      padding:0 14px;\r\n      border-radius:999px;\r\n      font-size:12px;\r\n      font-weight:700;\r\n      text-transform:uppercase;\r\n      letter-spacing:0.4px;\r\n    }\r\n    .form-footer-actions .btn-save-founder{\r\n      background:#1f6a2a;\r\n      border:1px solid #1f6a2a;\r\n      color:#fff;\r\n    }\r\n    .form-footer-actions .btn-cancel-founder{\r\n      background:#fff;\r\n      border:1px solid #cfe6d2;\r\n      color:#2e7d32;\r\n    }\r\n    .form-footer-actions .btn-save-founder:hover{ background:#1a5a23; border-color:#1a5a23; }\r\n    .form-footer-actions .btn-cancel-founder:hover{ background:#f3faf4; }\r\n\r\n    .add-btn{\r\n      background:#ddd;\r\n      color:#333;\r\n    }\r\n\r\n    .circle-plus{\r\n      width:24px;\r\n      height:24px;\r\n      border-radius:50%;\r\n      border:1px solid #2e7d32;\r\n      display:inline-flex;\r\n      align-items:center;\r\n      justify-content:center;\r\n      color:#2e7d32;\r\n      font-weight:bold;\r\n      font-size:16px;\r\n      cursor:pointer;\r\n      margin-right:8px;\r\n    }\r\n\r\n    .full-width{\r\n      margin-bottom:10px;\r\n    }\r\n\r\n    .muted{\r\n      font-size:12px;\r\n      color:#777;\r\n    }\r\n\r\n    input[type=\"text\"],\r\n    input[type=\"email\"],\r\n    input[type=\"tel\"],\r\n    select,\r\n    textarea{\r\n      width: 100%;\r\n      padding: 8px 10px;\r\n      border: 1px solid #ccc;\r\n      /* border-radius: 6px; */\r\n      font-size: 14px;\r\n      box-sizing: border-box;\r\n    }\r\n\r\n    .input-error{\r\n      border-color:#d32f2f !important;\r\n      outline:none;\r\n    }\r\n\r\n    .input-error-text{\r\n      color:#d32f2f;\r\n      font-size:12px;\r\n      margin-top:4px;\r\n    }\r\n\r\n    .subtitle{\r\n      font-size:13px;\r\n      font-weight:bold;\r\n      margin:15px 0 5px;\r\n    }\r\n\r\n    .multi-select-wrap {\r\n      position: relative;\r\n    }\r\n\r\n    .multi-select-input {\r\n      width: 100%;\r\n      padding: 8px 10px;\r\n      border: 1px solid #ccc;\r\n      box-sizing: border-box;\r\n      font-family: inherit;\r\n      font-size: 14px;\r\n      background: #fff;\r\n    }\r\n\r\n    .multi-select-dropdown {\r\n      position: absolute;\r\n      left: 0;\r\n      right: 0;\r\n      top: calc(100% + 2px);\r\n      z-index: 30;\r\n      background: #fff;\r\n      border: 1px solid #ccc;\r\n      max-height: 220px;\r\n      overflow: auto;\r\n      box-shadow: 0 2px 6px rgba(0,0,0,0.08);\r\n    }\r\n\r\n    .multi-select-item {\r\n      display: flex;\r\n      align-items: center;\r\n      gap: 8px;\r\n      padding: 6px 10px;\r\n      cursor: pointer;\r\n      margin: 0;\r\n      font-size: 14px;\r\n    }\r\n\r\n    .multi-select-item:hover {\r\n      background: #f7f7f7;\r\n    }\r\n\r\n    .multi-select-empty {\r\n      padding: 8px 10px;\r\n      color: #777;\r\n      font-size: 13px;\r\n    }\r\n\r\n    .inline-options{\r\n      display:flex;\r\n      flex-wrap:wrap;\r\n      gap:15px;\r\n      margin:5px 0 10px;\r\n    }\r\n\r\n    .section-title{\r\n      font-size:18px;\r\n      margin:0 0 10px;\r\n    }\r\n\r\n    .step-header{\r\n      display:flex;\r\n      align-items:center;\r\n      gap:10px;\r\n    }\r\n\r\n    .step-number{\r\n      font-weight:bold;\r\n      font-size:18px;\r\n      color:#777;\r\n    }\r\n\r\n    .nowrap{\r\n      white-space:nowrap;\r\n    }\r\n\r\n    .flex-line{\r\n      display:flex;\r\n      align-items:center;\r\n      gap:10px;\r\n    }\r\n\r\n    .flex-line label{\r\n      margin-bottom:0;\r\n    }\r\n\r\n    .step-nav{\r\n      display:flex;\r\n      align-items:center;\r\n      justify-content:space-between;\r\n      gap:12px;\r\n      margin:25px 0 10px;\r\n    }\r\n\r\n    .step-nav .left,\r\n    .step-nav .right{\r\n      display:flex;\r\n      gap:10px;\r\n      align-items:center;\r\n    }\r\n\r\n    .step-nav .progress{\r\n      font-size:13px;\r\n      color:#666;\r\n      white-space:nowrap;\r\n    }\r\n\r\n    .btn-secondary{\r\n      background:#ddd;\r\n      color:#333;\r\n    }\r\n\r\n    button:disabled{\r\n      opacity:0.55;\r\n      cursor:not-allowed;\r\n    }\r\n\r\n    .add-action{\r\n      display:flex;\r\n      align-items:center;\r\n      gap:8px;\r\n      cursor:pointer;\r\n      user-select:none;\r\n    }\r\n\r\n    .add-action span:last-child{\r\n      line-height:1.2;\r\n    }\r\n\r\n    .card_wrapper{\r\n      position:relative;\r\n      border:1px solid rgba(0,0,0,0.06);\r\n      border-radius:10px;\r\n      padding:16px;\r\n      margin-top:12px;\r\n      background:#fff;\r\n    }\r\n\r\n    .button_remove{\r\n      position:absolute;\r\n      top:10px;\r\n      right:10px;\r\n      width:28px;\r\n      height:28px;\r\n      border-radius:50%;\r\n      border:1px solid rgba(0,0,0,0.12);\r\n      background:#fff;\r\n      color:#555;\r\n      display:flex;\r\n      align-items:center;\r\n      justify-content:center;\r\n      cursor:pointer;\r\n    }\r\n\r\n    .fit{\r\n      display: flex;\r\n      align-items: center;\r\n    }\r\n\r\n    .inner_card{\r\n        margin-left:20px;\r\n        padding: 10px;\r\n        border-radius: 10px;\r\n        background-color: #eeeeee;\r\n    }\r\n\r\n\r\n    .field-row{\r\n      display:flex;\r\n      gap:12px;\r\n      margin-bottom:12px;\r\n      align-items:flex-end;\r\n      flex-wrap:wrap;\r\n    }\r\n    .field-row .field{\r\n      flex:1;\r\n      min-width:0;\r\n    }\r\n    .field-row .field--short{\r\n      flex:0 0 120px;\r\n    }\r\n    .contact-row{\r\n      display:grid;\r\n      grid-template-columns:80px 1fr 100px 1fr;\r\n      gap:12px;\r\n      margin-bottom:12px;\r\n    }\r\n    .contact-row label{\r\n      margin-bottom:5px;\r\n    }\r\n    @media (max-width: 600px){\r\n      .contact-row{\r\n        grid-template-columns:1fr 1fr;\r\n      }\r\n    }\r\n\r\n    #physical-person-founders-container,\r\n    #jur-person-founders-container {\r\n      margin-top: 16px;\r\n    }\r\n\r\n    .form-add-founder{\r\n      position: relative;\r\n      margin-bottom: 20px;\r\n    }\r\n    .form-add-founder.card,\r\n    .card-sponsor {\r\n      position: relative;\r\n      padding: 20px;\r\n      box-sizing: border-box;\r\n    }\r\n\r\n    /* Saved state: show as compact row list (like screenshot #2) */\r\n    .form-add-founder[data-state=\"saved\"],\r\n    .card-sponsor[data-state=\"saved\"] {\r\n      padding: 0;\r\n      margin-bottom: 10px;\r\n      background: transparent;\r\n      border: none;\r\n      box-shadow: none;\r\n      max-width: none;\r\n    }\r\n    .form-add-founder.card-physical-founder .button_remove,\r\n    .form-add-founder.card-jur-founder .button_remove,\r\n    .card-sponsor .button_remove{\r\n      position: absolute;\r\n      top: 10px;\r\n      right: 10px;\r\n    }\r\n    .jur-founders-inner,\r\n    .nested-founders-block {\r\n      margin-top: 16px;\r\n      margin-left: 20px;\r\n      padding-left: 12px;\r\n      border-left: 2px solid #e0e0e0;\r\n    }\r\n    .nested-founders-title {\r\n      font-weight: bold;\r\n      margin: 0 0 6px;\r\n      font-size: 14px;\r\n    }\r\n    .nested-founders-warning {\r\n      color: #c62828;\r\n      font-size: 13px;\r\n      margin: 0 0 12px;\r\n      font-weight: 500;\r\n    }\r\n    .nested-founder-item {\r\n      position: relative;\r\n      margin-bottom: 12px;\r\n      padding: 10px;\r\n      background: #fafafa;\r\n      border-radius: 6px;\r\n    }\r\n    .nested-founder-item .button_remove--small {\r\n      position: absolute;\r\n      top: 6px;\r\n      right: 6px;\r\n      width: 24px;\r\n      height: 24px;\r\n      padding: 0;\r\n      font-size: 18px;\r\n      line-height: 1;\r\n    }\r\n    .nested-founder-icon {\r\n      display: inline-block;\r\n      margin-right: 8px;\r\n      font-size: 1.1em;\r\n    }\r\n    .founders-sum {\r\n      margin: 10px 0 12px;\r\n      padding: 8px 10px;\r\n      font-weight: 600;\r\n      font-size: 14px;\r\n      border-radius: 4px;\r\n      display: flex;\r\n      align-items: center;\r\n      justify-content: space-between;\r\n      gap: 12px;\r\n    }\r\n    .founders-sum-text {\r\n      line-height: 1.2;\r\n    }\r\n    .founders-sum--complete {\r\n      background: #e8f5e9;\r\n      color: #2e7d32;\r\n    }\r\n    .founders-sum--incomplete {\r\n      background: #ffebee;\r\n      color: #c62828;\r\n    }\r\n    .nested-founders-actions {\r\n      display: flex;\r\n      flex-wrap: wrap;\r\n      gap: 10px;\r\n      margin-top: 0;\r\n      margin-left: auto;\r\n    }\r\n    .button_add_nested {\r\n      padding: 6px 10px;\r\n      background: transparent;\r\n      color: #2e7d32;\r\n      border: 1px solid #9fc9a4;\r\n      border-radius: 999px;\r\n      cursor: pointer;\r\n      font-size: 13px;\r\n      font-weight: 600;\r\n      line-height: 1.1;\r\n      white-space: nowrap;\r\n    }\r\n    .button_add_nested:hover {\r\n      background: #f3faf4;\r\n    }\r\n    .form-add-founder .notice-block{\r\n      color: #c62828;\r\n      font-size: 13px;\r\n      margin-bottom: 16px;\r\n      font-weight: 500;\r\n    }\r\n    .form-add-founder .physical-founder-title{\r\n      margin: 0 0 16px;\r\n      font-size: 16px;\r\n      font-weight: bold;\r\n    }\r\n    .form-add-founder .compliance-section{\r\n      margin-top: 20px;\r\n    }\r\n    .form-add-founder .compliance-section h3{\r\n      font-size: 14px;\r\n      margin: 0 0 12px;\r\n    }\r\n    .form-add-founder .compliance-item{\r\n      margin-bottom: 10px;\r\n    }\r\n    .form-add-founder .compliance-item .question{\r\n      font-size: 13px;\r\n      margin-bottom: 6px;\r\n    }\r\n    .form-add-founder .compliance-item .radios{\r\n      display: flex;\r\n      gap: 16px;\r\n    }\r\n    .form-add-founder .compliance-item label{\r\n      display: inline-flex;\r\n      align-items: center;\r\n      gap: 6px;\r\n      margin-bottom: 0;\r\n      cursor: pointer;\r\n    }\r\n\r\n    .founder-preview {\r\n      display: flex;\r\n      justify-content: space-between;\r\n      align-items: center;\r\n      padding: 10px 12px;\r\n      background: #fff;\r\n      border: 1px solid #e5e7eb;\r\n      border-radius: 8px;\r\n    }\r\n    .founder-preview-info {\r\n      display: flex;\r\n      align-items: center;\r\n      gap: 10px;\r\n      font-weight: 600;\r\n    }\r\n    .founder-icon { font-size: 18px; }\r\n    .founder-preview-actions {\r\n      display: flex;\r\n      align-items: center;\r\n      gap: 10px;\r\n    }\r\n    .founder-preview-actions .button_edit_founder,\r\n    .founder-preview-actions .button_remove_founder {\r\n      width: 28px;\r\n      height: 28px;\r\n      display: inline-flex;\r\n      align-items: center;\r\n      justify-content: center;\r\n      padding: 0;\r\n      background: #fff;\r\n      border-radius: 8px;\r\n      cursor: pointer;\r\n      color: #6b7280;\r\n      font-size: 14px;\r\n      line-height: 1;\r\n    }\r\n    .founder-preview-actions .button_edit_founder:hover,\r\n    .founder-preview-actions .button_remove_founder:hover {\r\n      color: #111827;\r\n      border-color: #d1d5db;\r\n      background: #f9fafb;\r\n    }\r\n  </style>\r\n</head>\r\n\r\n<body>\r\n\r\n<div class=\"container\">\r\n\r\n  <h1>ЗАЯВЛЕНИЕ О ГОСУДАРСТВЕННОЙ РЕГИСТРАЦИИ (ПЕРЕРЕГИСТРАЦИИ) СРЕДСТВА МАССОВОЙ ИНФОРМАЦИИ</h1>\r\n\r\n    <!-- ШАГ 1 -->\r\n    <div class=\"step\">\r\n\r\n        <div class=\"step-header\">\r\n            <div class=\"step-number\">ШАГ 1 из 6</div>\r\n            <h2 class=\"section-title\">Основные данные СМИ</h2>\r\n        </div>\r\n\r\n        <div class=\"card\">\r\n\r\n            <h3>1.1 Название и тип </h3>\r\n\r\n            <div class=\"full-width\">\r\n                <label>Название средства массовой информации:</label>\r\n                <input type=\"text\" data-path=\"mainInfo.name\" required=\"\" onchange=\"updateName(this.value)\">\r\n            </div>\r\n\r\n            <div class=\"row\">\r\n                <div>\r\n                    <label>Тип СМИ:</label>\r\n                    <select data-path=\"mainInfo.typeSmi\" required=\"\">\r\n                        <option value=\"\" selected=\"selected\" disabled=\"disabled\" hidden=\"\"></option>\r\n                        <option>Печатное СМИ</option>\r\n                        <option>Электронное СМИ</option>\r\n                        <option>Сетевое СМИ</option>\r\n                    </select>\r\n                </div>\r\n                <div>\r\n                    <label>Вид СМИ:</label>\r\n                    <select data-path=\"mainInfo.kindSmi\" onchange=\"handleKindSmiOtherChange(this)\" required=\"\">\r\n                        <option value=\"\" selected=\"selected\" disabled=\"disabled\" hidden=\"\"></option>\r\n                        <option>Сетевое издание</option>\r\n                        <option>Телепрограмма</option>\r\n                        <option>Радиопрограмма</option>\r\n                        <option>Газета</option>\r\n                        <option>Журнал</option>\r\n                        <option>Информационное агенство</option>\r\n                        <option>Альманах</option>\r\n                        <option>Календарь</option>\r\n                        <option>Каталог</option>\r\n                        <option>Другое</option>\r\n                    </select>\r\n                </div>\r\n            </div>\r\n            <div class=\"row\">\r\n                <div>\r\n                    <label>Другой вид СМИ(заполните, если это не этот пункт в списке выше)</label>\r\n                    <input type=\"text\" data-path=\"mainInfo.kindSmiOther\" disabled=\"disabled\">\r\n                </div>\r\n            </div>\r\n\r\n        </div>\r\n\r\n    </div>\r\n\r\n    <!-- ШАГ 2 -->\r\n    <div class=\"step active\">\r\n\r\n        <div class=\"step-header\">\r\n            <div class=\"step-number\">ШАГ 2 из 6</div>\r\n            <h2 class=\"section-title\">Учредители (владелец) СМИ</h2>\r\n        </div>\r\n\r\n        <div class=\"card\">\r\n\r\n            <h3>2.1 Тип</h3>\r\n\r\n            <div class=\"inline-options\">\r\n                <label><input type=\"radio\" name=\"founder_type\" value=\"jurFace\" checked=\"checked\" onchange=\"changeFace()\">Учредитель</label>\r\n                <label><input type=\"radio\" name=\"founder_type\" value=\"fizFace\" onchange=\"changeFace()\">Владелец сетевого издания</label>\r\n            </div>\r\n\r\n        </div>\r\n\r\n\r\n        <div id=\"founder\" class=\"card\">\r\n\r\n            <h3>2.2 Реквизиты учредителей сми <span id=\"person_name\"></span></h3>\r\n\r\n            <div style=\"margin-left:20px\">\r\n                <div id=\"filler_2_2_list\">\r\n                  <hr>\r\n                    <label>Список учередителей пока пуст(поменять фикс маргин у дива выше и при создании ниже)</label>\r\n                  <hr>\r\n                </div>\r\n                <div id=\"min_founder\"></div>\r\n                <div id=\"physical-person-founders-container\"></div>\r\n                <div id=\"jur-person-founders-container\"></div>\r\n                <div class=\"row\">\r\n                    <div>\r\n                        <div class=\"add-action\" data-add-physical-founder>\r\n                            <span class=\"circle-plus\">+</span>\r\n                            <span>Добавить владельца - физическое лицо</span>\r\n                        </div>\r\n                    </div>\r\n                    <div>\r\n                        <div class=\"add-action\" data-add-jur-founder>\r\n                            <span class=\"circle-plus\">+</span>\r\n                            <span>Добавить владельца - юридическое лицо</span>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n\r\n        <div id=\"domainOwner\" class=\"card\" style=\"display: none\" data-ignore-container=\"\">\r\n            <h3>2.2 Владелец сетевого издания</h3>\r\n            <div class=\"row\">\r\n                <div>\r\n                    <div class=\"add-action\" data-domain-owner-add=\"fiz\">\r\n                        <span class=\"circle-plus\">+</span>\r\n                        <span>Добавить владельца - физическое лицо</span>\r\n                    </div>\r\n                </div>\r\n                <div>\r\n                    <div class=\"add-action\" data-domain-owner-add=\"jur\">\r\n                        <span class=\"circle-plus\">+</span>\r\n                        <span>Добавить владельца - юридическое лицо</span>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n            <div id=\"domain-owner-container\"></div>\r\n        </div>\r\n\r\n    </div>\r\n\r\n\r\n  <!-- ШАГ 3 -->\r\n  <div class=\"step\">\r\n\r\n    <div class=\"step-header\">\r\n      <div class=\"step-number\">ШАГ 3 из 6</div>\r\n      <h2 class=\"section-title\">Сведения о редакции</h2>\r\n    </div>\r\n\r\n    <div class=\"card\">\r\n\r\n      <h3>3.1 Юридическое лицо, выполняющие функции редакции</h3>\r\n\r\n      <div class=\"full-width\">\r\n        <label>Полное наименование юридического лица:</label>\r\n        <input type=\"text\" data-path=\"office.fullName\" required=\"\">\r\n      </div>\r\n\r\n      <div class=\"row\">\r\n        <div>\r\n          <label>Резидент какой страны:</label>\r\n          <select data-path=\"office.country\" required=\"\">\r\n              <option value=\"\" selected=\"selected\" disabled=\"disabled\" hidden=\"\"></option>\r\n              <option>Республика Беларусь</option>\r\n              <option>Российская Федерация</option>\r\n              <option>Латвия</option>\r\n              <option>Литва</option>\r\n              <option>Эстония</option>\r\n              <option>Польша</option>\r\n  \r\n          </select>\r\n        </div>\r\n      </div>\r\n      <div class=\"full-width\">\r\n        <div>\r\n          <label>Адрес(индекс, область, район, город, улица, дом, корпус, офис)</label>\r\n          <input type=\"text\" data-path=\"office.address\" required=\"\">\r\n        </div>\r\n      </div>\r\n\r\n      <h5>Контактные данные:</h5>\r\n\r\n      <div class=\"row\">\r\n        <div class=\"flex-line\">\r\n            <div>\r\n                <label>Код города:</label>\r\n                <input type=\"tel\" inputmode=\"numeric\" data-path=\"office.phoneCode\" required=\"\" data-validate=\"phoneCode\">\r\n            </div>\r\n            <div>\r\n                <label>Телефон:</label>\r\n                <input type=\"tel\" data-path=\"office.phone\" required=\"\" data-validate=\"phone\">\r\n            </div>\r\n            <div>\r\n                <label>Факс:</label>\r\n                <input type=\"text\" data-path=\"office.fax\" required=\"\">\r\n            </div>\r\n            <div>\r\n                <label>Email:</label>\r\n                <input type=\"email\" data-path=\"office.email\" required=\"\" data-validate=\"email\">\r\n            </div>\r\n        </div>\r\n      </div>\r\n      <div class=\"full-width\">\r\n        <div>\r\n            <label>Адрес веб сайта:</label>\r\n            <input type=\"text\" data-path=\"office.www\">\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"inline-options\">\r\n        <label>\r\n          <input type=\"radio\" name=\"room\" value=\"true\" data-path=\"office.meetsLegalRqmts\"> Да\r\n          <input type=\"radio\" name=\"room\" value=\"false\" data-path=\"office.meetsLegalRqmts\" checked=\"checked\"> Нет\r\n          <span>Помещение, в котором размещается юридическое лицо, на \r\n            которое возложены функции редакции средства массовой информации,\r\n            соответствует требованиям законодательства</span>\r\n        </label>\r\n      </div>\r\n\r\n      <div class=\"row\">\r\n        <div>\r\n            <label>Тип помещения:</label>\r\n            <select data-path=\"office.room\" required=\"\">\r\n                <option value=\"\" selected=\"selected\" disabled=\"disabled\" hidden=\"\"></option>\r\n                <option>Жилом помещении</option>\r\n                <option>Нежилом помещении</option>\r\n                <option>Помещении, которое переведено из жилого в нежилое</option>\r\n            </select>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n\r\n    <div class=\"card\">\r\n      <h3>3.2 Сведения о собственниках имущества этого юрлица</h3>\r\n      <div id=\"office-owners-container\"></div>\r\n      <div class=\"row\">\r\n        <div>\r\n          <div class=\"add-action\" data-add-office-owner=\"fiz\">\r\n            <span class=\"circle-plus\">+</span>\r\n            <span>Добавить владельца – физическое лицо</span>\r\n          </div>\r\n        </div>\r\n        <div>\r\n          <div class=\"add-action\" data-add-office-owner=\"jur\">\r\n            <span class=\"circle-plus\">+</span>\r\n            <span>Добавить владельца – юридическое лицо</span>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"card\">\r\n        <h3>3.3 Главный редактор</h3>\r\n        <div class=\"full-width\">\r\n            <label>Ф.И.О.:</label>\r\n            <input type=\"text\" data-path=\"office.chiefEditor.name\" required=\"\">\r\n        </div>\r\n        <div class=\"row\">\r\n            <div>\r\n                <label>Гражданство:</label>\r\n                <select data-path=\"office.chiefEditor.country\" required=\"\">\r\n                    <option value=\"\" selected=\"selected\" disabled=\"disabled\" hidden=\"\"></option> \r\n                    <option>Гражданин Республики Беларусь</option>\r\n                    <option>Иностранный гражданин</option>\r\n                    <option>Лицо без гражданства</option>\r\n                </select>\r\n            </div>\r\n            <div>\r\n                <label>Данные акта о назначении(номер, дата приказа и т.д.)</label>\r\n                <input type=\"text\" data-path=\"office.chiefEditor.actAssignment\" required=\"\">\r\n            </div>\r\n        </div>\r\n        <label>\r\n            <input type=\"radio\" name=\"qualification\" value=\"true\" data-path=\"office.chiefEditor.meetRequirements\"> Да\r\n            <input type=\"radio\" name=\"qualification\" value=\"false\" data-path=\"office.chiefEditor.meetRequirements\" checked=\"checked\"> Нет\r\n            <span>Главный редактор соответствует квалификационным требованиям</span>\r\n        </label>\r\n        <h7>Образование:</h7>\r\n\r\n        <div class=\"row\">\r\n            <div>\r\n                <label>Учебное заведение, которое окончил главный редактор (редактор), год поступления(окончания)</label>\r\n                <input type=\"text\" data-path=\"office.chiefEditor.institution\" required=\"\">\r\n            </div>\r\n        </div>\r\n\r\n        <h7>Сведения о работе на руководящих должностях:</h7>\r\n        <div class=\"row\">\r\n            <div>\r\n                <label>Место работы, должность, период работы</label>\r\n                <input type=\"text\" data-path=\"office.chiefEditor.formerJobInfo\" required=\"\">\r\n            </div>\r\n        </div>\r\n      </div>\r\n\r\n  </div>\r\n\r\n\r\n  <!-- ШАГ 4 -->\r\n  <div class=\"step\">\r\n\r\n    <div class=\"step-header\">\r\n      <div class=\"step-number\">ШАГ 4 из 6</div>\r\n      <h2 class=\"section-title\">Тематика и распространение СМИ</h2>\r\n    </div>\r\n\r\n    <div class=\"card\">\r\n\r\n      <h3>4.1 Специализация и тематика</h3>\r\n\r\n      <div class=\"full-width\">\r\n        <label>Специализация (начните вводить, чтобы увидеть варианты, или выберите из списка):</label>\r\n        <select data-path=\"mainInfo.specialization\" data-search-multi=\"true\" multiple required=\"\">\r\n            <option value=\"\" selected=\"selected\" disabled=\"disabled\" hidden=\"\"></option>\r\n            <option>Общеполитическая</option>\r\n            <option>Специализированная-официальная</option>\r\n            <option>Научная</option>\r\n            <option>Научно-популярная</option>\r\n            <option>Литературно-художественная</option>\r\n            <option>Производственно-практическая</option>\r\n            <option>Нормативная производственно-практическая</option>\r\n            <option>Учебная</option>\r\n            <option>Массово-политическая</option>\r\n            <option>Духовно-просветительская</option>\r\n            <option>Справочная</option>\r\n            <option>Рекламная</option>\r\n            <option>Для досуга</option>\r\n            <option>Литературно-художественный</option>\r\n            <option>Общественно-политический</option>\r\n            <option>Популярный</option>\r\n            <option>Научный</option>\r\n            <option>Научно-популярный</option>\r\n            <option>Рекламный</option>\r\n            <option>Справочный</option>\r\n            <option>Духовно-просветительский</option>\r\n            <option>Производственно-практический</option>\r\n            <option>Нормативный производственно-практический</option>\r\n            <option>Реферативный</option>\r\n            <option>Бюллетень-таблица</option>\r\n            <option>Статистический бюллетень</option>\r\n            <option>Бюллетень-хроника</option>\r\n            <option>Нормативный</option>\r\n            <option>Информационная</option>\r\n            <option>Информационно-аналитическая</option>\r\n            <option>Специализированная информационная</option>\r\n            <option>Публицистическая</option>\r\n            <option>Развлекательная</option>\r\n            <option>Детская</option>\r\n            <option>Музыкальная</option>\r\n            <option>Спортивная</option>\r\n            <option>Образовательная</option>\r\n            <option>Культурно-просветительная</option>\r\n            <option>Духовно-просветительная</option>\r\n            <option>Демонстрация художественных(игровых) кинофильмов</option>\r\n        </select>\r\n        <span class=\"subtitle\">Выбранные варианты: <span class=\"selected-values\">Не выбрано</span></span>\r\n      </div>\r\n      <div>\r\n        <label>\r\n            <input type=\"checkbox\" data-path=\"mainInfo.specializationOtherEnabled\" onclick=\"toggleActive('specializationOther')\">\r\n            Другая (впишите в поле свою специализацию, если её нет в списке выше):\r\n        </label>\r\n      </div>\r\n      <div class=\"full-width\">\r\n        <input id=\"specializationOther\" type=\"text\" data-path=\"mainInfo.specializationOther\" disabled=\"disabled\">\r\n      </div>\r\n\r\n        <hr>\r\n      <div class=\"full-width\">\r\n        <label>Тематика (начните вводить, чтобы увидеть варианты):</label>\r\n        <select data-path=\"mainInfo.subjects\" data-search-multi=\"true\" multiple required=\"\">\r\n            <option value=\"\" selected=\"selected\" disabled=\"disabled\" hidden=\"\"></option>\r\n            <option>Военное дело</option>\r\n            <option>Государство</option>\r\n            <option>Детектив</option>\r\n            <option>Детская</option>\r\n            <option>Для женщин и мужчин</option>\r\n            <option>Домашнее хозяйство</option>\r\n            <option>Жилищно-коммунальное хозяйство</option>\r\n            <option>Защита животных</option>\r\n            <option>Здоровье</option>\r\n            <option>Информатика</option>\r\n            <option>Искусство</option>\r\n            <option>История</option>\r\n            <option>Книговедение</option>\r\n            <option>Компьютерная</option>\r\n            <option>Краеведение</option>\r\n            <option>Культура</option>\r\n            <option>Лесное хозяйство</option>\r\n            <option>Медицина</option>\r\n            <option>Молодежная</option>\r\n            <option>Образование</option>\r\n            <option>Общественное питание</option>\r\n            <option>Педагогика</option>\r\n            <option>Печать</option>\r\n            <option>Полиграфия</option>\r\n            <option>Потребкооперация</option>\r\n            <option>Право</option>\r\n            <option>Правопорядок</option>\r\n            <option>Предпринимательство</option>\r\n            <option>Природа</option>\r\n            <option>Продовольствие</option>\r\n            <option>Промышленность</option>\r\n            <option>Психология</option>\r\n            <option>Радиоэлектроника</option>\r\n            <option>Религия</option>\r\n            <option>Сатира и юмор</option>\r\n            <option>Связь</option>\r\n            <option>Сельское хозяйство</option>\r\n            <option>Семья</option>\r\n            <option>Социальная защита</option>\r\n            <option>Социология</option>\r\n            <option>Спорт</option>\r\n            <option>Статистика</option>\r\n            <option>Страхование</option>\r\n            <option>Строительство</option>\r\n            <option>Техника</option>\r\n            <option>Торговля</option>\r\n            <option>Транспорт</option>\r\n            <option>Труд</option>\r\n            <option>Туризм</option>\r\n            <option>Управление\r\n        </option></select>\r\n        <span class=\"subtitle\">Выбранные варианты: <span class=\"selected-values\">Не выбрано</span></span>\r\n      </div>\r\n      <div>\r\n        <label>\r\n            <input type=\"checkbox\" data-path=\"mainInfo.subjectsOtherEnabled\" onclick=\"toggleActive('subjectsOther')\">\r\n            Другая (впишите в поле свою тематику, если её нет в списке выше):\r\n        </label>\r\n      </div>\r\n      <div class=\"full-width\">\r\n        <input id=\"subjectsOther\" type=\"text\" data-path=\"mainInfo.subjectsOther\" disabled=\"disabled\">\r\n      </div>\r\n    </div>\r\n\r\n\r\n    <div class=\"card\">\r\n\r\n      <!-- Это не обзазательные поля -->\r\n      <h3>4.2 Периодичность и объем СМИ</h3>\r\n\r\n      <div class=\"subtitle\">Периодичность средства массовой информации:</div>\r\n\r\n      <div class=\"inline-options\">\r\n        <label><input type=\"radio\" name=\"periodicity\" value=\"Ежедневно\" data-path=\"mainInfo.periodicity\" checked=\"checked\"> Ежедневно</label>\r\n        <label><input type=\"radio\" name=\"periodicity\" value=\"Еженедельно\" data-path=\"mainInfo.periodicity\"> Еженедельно</label>\r\n        <label><input type=\"radio\" name=\"periodicity\" value=\"Несколько раз в неделю\" data-path=\"mainInfo.periodicity\"> Несколько раз в неделю</label>\r\n        <label><input type=\"radio\" name=\"periodicity\" value=\"Ежемесячно\" data-path=\"mainInfo.periodicity\"> Ежемесячно</label>\r\n        <label><input type=\"radio\" name=\"periodicity\" value=\"Один раз в два месяца\" data-path=\"mainInfo.periodicity\"> Один раз в два месяца</label>\r\n        <label><input type=\"radio\" name=\"periodicity\" value=\"Ежеквартально\" data-path=\"mainInfo.periodicity\"> Ежеквартально</label>\r\n        <label><input type=\"radio\" name=\"periodicity\" value=\"Один раз в полугодие\" data-path=\"mainInfo.periodicity\"> Один раз в полугодие</label>\r\n        <label><input type=\"radio\" name=\"periodicity\" value=\"Другое\" data-path=\"mainInfo.periodicity\"> Другое:</label>\r\n      </div>\r\n      <div class=\"full-width\">\r\n        <input type=\"text\" data-path=\"mainInfo.periodicityOther\" disabled=\"disabled\">\r\n      </div>\r\n\r\n      <div class=\"subtitle\">Максимальный объём вещания:</div>\r\n\r\n      <div class=\"inline-options\">\r\n        <label><input type=\"radio\" name=\"volumeVoice\" value=\"до 1 часа\" data-path=\"mainInfo.volumeVoice\" checked=\"checked\"> до 1 часа</label>\r\n        <label><input type=\"radio\" name=\"volumeVoice\" value=\"1 - 6 часов\" data-path=\"mainInfo.volumeVoice\"> 1 - 6 часов</label>\r\n        <label><input type=\"radio\" name=\"volumeVoice\" value=\"6 - 12 часов\" data-path=\"mainInfo.volumeVoice\"> 6 - 12 часов</label>\r\n        <label><input type=\"radio\" name=\"volumeVoice\" value=\"12 - 18 часов\" data-path=\"mainInfo.volumeVoice\"> 12 - 18 часов</label>\r\n        <label><input type=\"radio\" name=\"volumeVoice\" value=\"до 24 часов\" data-path=\"mainInfo.volumeVoice\"> до 24 часов</label>\r\n        <label><input type=\"radio\" name=\"volumeVoice\" value=\"Другое\" data-path=\"mainInfo.volumeVoice\"> Другое:</label>\r\n      </div>\r\n      <div class=\"full-width\">\r\n        <input type=\"text\" data-path=\"mainInfo.volumeVoiceOther\" disabled=\"disabled\">\r\n      </div>\r\n\r\n      <div class=\"full-width flex-line\">\r\n        <label>Ежемесячный объём материалов белорусского производства(для телевизионного СМИ), %</label>\r\n        <input type=\"number\" inputmode=\"numeric\" data-path=\"mainInfo.bynVolume\" data-validate=\"percent\">\r\n      </div>\r\n    <div class=\"full-width flex-line\">\r\n        <label>Предпологаемый тираж массовой информации (для печатного средства массовой информации):</label>\r\n        <input type=\"number\" inputmode=\"numeric\" data-path=\"mainInfo.circulation\">\r\n    </div>\r\n    </div>\r\n\r\n    <div class=\"card\">\r\n\r\n        <h3>4.3 Периодичность и территория распространения</h3>\r\n  \r\n        <div class=\"subtitle\">Языки распространения:</div>\r\n\r\n        <div class=\"inline-options\">\r\n            <label><input type=\"checkbox\" value=\"Русский\" data-path=\"mainInfo.language\"> Русский</label>\r\n            <label><input type=\"checkbox\" value=\"Белорусский\" data-path=\"mainInfo.language\"> Белорусский</label>\r\n            <label><input type=\"checkbox\" value=\"Украинский\" data-path=\"mainInfo.language\"> Украинский</label>\r\n            <label><input type=\"checkbox\" value=\"Польский\" data-path=\"mainInfo.language\"> Польский</label>\r\n            <label><input type=\"checkbox\" value=\"Немецкий\" data-path=\"mainInfo.language\"> Немецкий</label>\r\n            <label><input type=\"checkbox\" value=\"Французский\" data-path=\"mainInfo.language\"> Французский</label>\r\n            <label><input type=\"checkbox\" value=\"Испанский\" data-path=\"mainInfo.language\"> Испанский</label>\r\n            <label><input type=\"checkbox\" value=\"Другое\" data-path=\"mainInfo.languageOther\" onclick=\"toggleActive('languageOtherText')\"> Другое:</label>\r\n        </div>\r\n        <div class=\"full-width\">\r\n            <input id=\"languageOtherText\" type=\"text\" data-path=\"mainInfo.languageOtherText\" disabled=\"disabled\">\r\n        </div>\r\n\r\n        \r\n        <div class=\"subtitle\">Предполагаемая территория распростанения средства массовой информации:</div>\r\n        <div class=\"inline-options\">\r\n            <label><input type=\"radio\" name=\"distributionTerritory\" value=\"Международная\" data-path=\"mainInfo.distributionTerritory\" checked=\"checked\"> Международная</label>\r\n            <label><input type=\"radio\" name=\"distributionTerritory\" value=\"Республика Беларусь\" data-path=\"mainInfo.distributionTerritory\"> Республика Беларусь</label>\r\n            <label><input type=\"radio\" name=\"distributionTerritory\" value=\"Область\" data-path=\"mainInfo.distributionTerritory\"> Область</label>\r\n            <label><input type=\"radio\" name=\"distributionTerritory\" value=\"Район\" data-path=\"mainInfo.distributionTerritory\"> Район</label>\r\n            <label><input type=\"radio\" name=\"distributionTerritory\" value=\"Город\" data-path=\"mainInfo.distributionTerritory\"> Город</label>\r\n            <label><input type=\"radio\" name=\"distributionTerritory\" value=\"Населённый пункт\" data-path=\"mainInfo.distributionTerritory\"> населенный пункт</label>\r\n            <label><input t